<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>UatDotnetFixture</RootNamespace>
    <AssemblyName>UatDotnetFixture</AssemblyName>
    <Deterministic>true</Deterministic>
    <PathMap>$(MSBuildProjectDirectory)=/_/</PathMap>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- One package reference so the DotnetDependenciesData probe panel has
         something concrete to surface. EF Core is the per-README "notable dep"
         choice. Version pinned for reproducibility. -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0-preview.4.25258.110" />
  </ItemGroup>

</Project>
