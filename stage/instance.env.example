# Collabhost stage instance contract -- the TOLD INPUTS for deploy-stage.sh (card #443).
#
# Theo's one-time box stand-up writes the real file at /etc/collabhost-stage/instance.env,
# root-owned and READABLE BY THE stage-deploy USER (e.g. 0640 root:stage-deploy). The
# deploy script + seed source it; every writable location is told here, never discovered
# (Standard Hosting rule #1). A missing required key fails the deploy LOUD (rule #4) --
# the script never guesses an isolation value.
#
# This .example is the reconcile artifact between Remy's deploy half and Theo's box half:
# the key set the script REQUIRES. Values below mirror the Stage Instance Contract
# (stage-env-it-design.md §4) with decision #2 (alt-ports :8080/:8443 + internal CA).
# Copy, fill in the real STAGE_ADMIN_KEY (a fixed ULID), and adjust paths/RID to the box.

# ---- Service + identity -------------------------------------------------------
STAGE_SERVICE=collabhost-stage.service
STAGE_USER=collabhost-stage

# ---- Install prefix (binary + caddy + wwwroot + docs; collabhost-stage-owned) -
# Stage relaxation vs prod: the prefix is owned by the stage SERVICE user so the
# deploy swaps it via `runuser -u collabhost-stage` (prod keeps binaries root-owned).
STAGE_PREFIX=/opt/collabhost-stage

# ---- Config (smart-merged each deploy; collabhost-stage-owned) ----------------
STAGE_CONFIG=/etc/collabhost-stage/appsettings.json
STAGE_CONFIG_BASELINE=/etc/collabhost-stage/appsettings.shipped.json

# ---- State (wiped on a clean deploy, guarded; collabhost-stage-owned) ---------
STAGE_DATA_ROOT=/var/lib/collabhost-stage
STAGE_DATA=/var/lib/collabhost-stage/data
STAGE_APP_DATA=/var/lib/collabhost-stage/app-data
STAGE_CADDY_STORAGE=/var/lib/collabhost-stage/caddy
STAGE_SRV=/srv/stage

# ---- Build-on-box source checkout (stage-deploy-owned; readable by stage user) -
# Lives UNDER the stage prefix on purpose, so the stage service user can traverse +
# read the build output for the swap (the build runs as stage-deploy; the swap reads
# it as collabhost-stage). 0755 dirs.
STAGE_SRC=/opt/collabhost-stage/src
STAGE_REPO_URL=https://github.com/MrBildo/collabhost.git
# git remote name inside STAGE_SRC (default: origin)
#STAGE_GIT_REMOTE=origin

# ---- Build target -------------------------------------------------------------
# The box RID. linux-x64 or linux-arm64 -- decides `dotnet publish -r` (and, for
# STAGE_CADDY_SOURCE=build, the Caddy cross-compile target via build-caddy.sh).
STAGE_RID=linux-x64

# Bundled Caddy: build (mirror the prod publish from the ref's pins -- exercises a
# caddy.version bump on stage; needs Go on the box) | copy (prod's bundled caddy --
# zero Go toolchain, but does not test the ref's Caddy). Default: build.
STAGE_CADDY_SOURCE=build
PROD_CADDY_PATH=/opt/collabhost/bin/caddy

# Wipe the internal CA on a clean deploy too (regenerates certs; the box must then
# re-trust stage's CA). Default 0 -- keep the CA so the one-time "trust the stage CA"
# step from stand-up survives wipes.
#STAGE_WIPE_CADDY=0

# ---- Control plane (the seed registers against this) --------------------------
STAGE_BASE_URL=http://localhost:58500
# Fixed stage admin key (a ULID). The same key the stage unit boots with
# (COLLABHOST_ADMIN_KEY). Must be readable here so the seed can authenticate.
STAGE_ADMIN_KEY=REPLACE_WITH_FIXED_STAGE_ULID

# Readiness wait + optional through-proxy smoke (warn-only; depends on stage DNS /
# edge-bind, which is Theo's half). e.g. https://demo-dotnet-api.stage.collab.internal:8443
#STAGE_READY_TIMEOUT=90
#STAGE_SMOKE_APP_URL=

# ---- Prod anchors (the wipe guard's denylist) ---------------------------------
# Named so assert_wipe_target can refuse to touch prod even on an env typo. Belt-and-
# suspenders atop the kernel perms (stage user can't write prod) + the prod-pathless
# sudoers (Theo's dispatcher half).
PROD_DATA=/var/lib/collabhost
PROD_PREFIX=/opt/collabhost
PROD_CONFIG_DIR=/etc/collabhost
