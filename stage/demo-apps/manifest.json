{
  "_comment": [
    "Curated demo set for the Collabhost stage instance (cards #443 / #440).",
    "Data-driven: deploy-stage.sh's seed (seed-demo-apps.sh) reads this file and",
    "registers every app whose slug is not already present (register-if-absent,",
    "idempotent). This curated selection drives the #440 doc screenshots -- it is a",
    "Dana/Bill call. It covers every distinct dashboard row shape with realistic,",
    "operator-recognizable apps: two .NET services (one carrying real NuGet refs so",
    "the Technology tab shows a populated dependency probe), two Node services (one",
    "left STOPPED for status variety), a static docs site, an external route, and",
    "two supervised internal services (a database + a key-value store -- the",
    "canonical internal-service shapes).",
    "",
    "Per-app fields:",
    "  slug, displayName, appType   -- registration identity + type",
    "  artifactSource               -- dir under stage/demo-apps/ copied to /srv/stage/<slug> (omit for route-only types)",
    "  artifactSubpath              -- subdir of the copied tree that is the artifact (e.g. a build output dir)",
    "  build                        -- shell command run in the copied dir AS the stage user (omit if none)",
    "  requires                     -- space-separated tools that must be on PATH; if absent the app is skipped with a warning",
    "  start                        -- POST /start after registering (default true)",
    "  values                       -- registration overrides (section -> field -> value); '{artifact}' resolves to the absolute on-box artifact path"
  ],
  "apps": [
    {
      "slug": "metrics-api",
      "displayName": "Metrics API",
      "appType": "dotnet-app",
      "artifactSource": "metrics-api",
      "artifactSubpath": "publish",
      "build": "dotnet publish -c Release -o publish --nologo",
      "requires": "dotnet",
      "start": true,
      "values": {
        "artifact": { "location": "{artifact}" }
      }
    },
    {
      "slug": "auth-service",
      "displayName": "Auth Service",
      "appType": "dotnet-app",
      "artifactSource": "auth-service",
      "artifactSubpath": "publish",
      "build": "dotnet publish -c Release -o publish --nologo",
      "requires": "dotnet",
      "start": true,
      "values": {
        "artifact": { "location": "{artifact}" }
      }
    },
    {
      "slug": "webhook-relay",
      "displayName": "Webhook Relay",
      "appType": "nodejs-app",
      "artifactSource": "webhook-relay",
      "artifactSubpath": "",
      "build": "npm install --omit=dev --no-audit --no-fund",
      "requires": "npm node",
      "start": true,
      "values": {
        "artifact": { "location": "{artifact}" }
      }
    },
    {
      "slug": "notify-worker",
      "displayName": "Notification Worker",
      "appType": "nodejs-app",
      "artifactSource": "notify-worker",
      "artifactSubpath": "",
      "build": "npm install --omit=dev --no-audit --no-fund",
      "requires": "npm node",
      "start": false,
      "values": {
        "artifact": { "location": "{artifact}" }
      }
    },
    {
      "slug": "internal-docs",
      "displayName": "Internal Docs",
      "appType": "static-site",
      "artifactSource": "internal-docs",
      "artifactSubpath": "",
      "build": "",
      "requires": "",
      "start": true,
      "values": {
        "artifact": { "location": "{artifact}" }
      }
    },
    {
      "slug": "grafana",
      "displayName": "Grafana",
      "appType": "external-route",
      "build": "",
      "requires": "",
      "start": true,
      "values": {
        "external-target": { "host": "127.0.0.1", "port": 58500, "scheme": "http" }
      }
    },
    {
      "slug": "postgres",
      "displayName": "Postgres",
      "appType": "internal-service",
      "artifactSource": "postgres",
      "artifactSubpath": "",
      "build": "",
      "requires": "node",
      "start": true,
      "values": {
        "artifact": { "location": "{artifact}" },
        "process": {
          "discoveryStrategy": "Manual",
          "command": "node",
          "arguments": "{artifact}/heartbeat.js postgres"
        }
      }
    },
    {
      "slug": "valkey",
      "displayName": "Valkey",
      "appType": "internal-service",
      "artifactSource": "valkey",
      "artifactSubpath": "",
      "build": "",
      "requires": "node",
      "start": true,
      "values": {
        "artifact": { "location": "{artifact}" },
        "process": {
          "discoveryStrategy": "Manual",
          "command": "node",
          "arguments": "{artifact}/heartbeat.js valkey"
        }
      }
    }
  ]
}
