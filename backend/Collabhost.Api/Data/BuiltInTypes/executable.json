{
  "slug": "executable",
  "displayName": "Executable",
  "description": "Generic binary with port injection and reverse proxy routing",
  "bindings": {
    "artifact": {
      "location": ""
    },
    "process": {
      "discoveryStrategy": "Manual",
      "shutdownTimeoutSeconds": 10
    },
    "port-injection": {
      "environmentVariableName": "PORT",
      "portFormat": "{port}"
    },
    "routing": {
      "domainPattern": "{slug}.{baseDomain}",
      "serveMode": "ReverseProxy",
      "spaFallback": false
    },
    "restart": {
      "policy": "OnCrash"
    },
    "auto-start": {
      "enabled": false
    }
  }
}
