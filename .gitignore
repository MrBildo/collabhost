node_modules/
frontend/node_modules/
frontend/dist/

# .NET
backend/**/bin/
backend/**/obj/

# Aspire local state
.aspire/
aspire.config.json

# Collabhost app
backend/Collabhost.Api/wwwroot/
*.db
*.db-shm
*.db-wal
*.db.bak-*
backend/Collabhost.Api/db/
