{
  "slug": "static-site",
  "displayName": "Static Site",
  "description": "Static files served by Caddy",
  "bindings": {
    "artifact": {
      "location": ""
    },
    "routing": {
      "domainPattern": "{slug}.{baseDomain}",
      "serveMode": "FileServer",
      "spaFallback": false,
      "responseHeaders": {
        "/config.json::Cache-Control": "no-cache"
      }
    }
  }
}
