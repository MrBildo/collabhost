{
  "slug": "static-site",
  "displayName": "Static Site",
  "description": "Static files served by Caddy",
  "bindings": {
    "artifact": {
      "location": ""
    },
    "routing": {
      "domainPattern": "{slug}.{baseDomain}",
      "serveMode": "FileServer",
      "spaFallback": false,
      "responseHeaders": {
        "/config.json::Cache-Control": "no-cache"
      }
    },
    "runtime-config-file": {
      "path": "/config.json",
      "values": {}
    },
    "security-headers": {
      "enableHsts": false,
      "hstsMaxAgeSeconds": 300,
      "headers": {
        "X-Content-Type-Options": "nosniff"
      }
    }
  }
}
