{
  "ConnectionStrings": {
    "Host": "Data Source=./data/collabhost.db"
  },
  "Auth": {
    "AdminKey": null
  },
  "TypeStore": {
    "UserTypesDirectory": "UserTypes"
  },
  "Hosting": {
    "ListenPort": 58400
  },
  "Proxy": {
    "BaseDomain": "collab.internal",
    "BinaryPath": "",
    "ListenAddress": ":80,:443",
    "CertLifetime": "168h",
    "DnsProvider": "",
    "DnsApiTokenEnvVar": "CLOUDFLARE_API_TOKEN"
  },
  "Portal": {
    "Subdomain": "collabhost"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Diagnostics": {
    "CrashLogs": {
      "Directory": null,
      "Retention": 10
    }
  }
}
