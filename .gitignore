backend/Collabhost.Api/Data/backups/

# IDE / editor
.vscode/
.vs/
.playwright-cli/

# Secrets / env
backend/**/Properties/launchSettings.json
!backend/Collabhost.AppHost/Properties/launchSettings.json
!backend/Collabhost.Api/Properties/launchSettings.json
backend/**/appsettings.Development.json
frontend/.env
frontend/.env.*

# Build info
frontend/tsconfig.tsbuildinfo
frontend/src/**/*.js

# Frontend test artifacts
frontend/junit.xml

# UAT fixture build output (recipes tracked under docs/uat-fixtures/recipes/, output is not)
docs/uat-fixtures/build/

# Playwright MCP
.playwright-mcp/

# Local tools -- ignore everything by default (downloaded binaries, scratch
